    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "dotenv": "16.4.5",
    "googleapis": "140.0.1",
    "pino": "9.0.0",
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "@types/node": "20.12.7",
    "@types/pino": "7.0.5",
    "@types/qrcode-terminal": "0.12.2",
    "@vitest/coverage-v8": "2.1.9",
    "tsx": "4.19.1",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "vitest": "2.1.9"
  }
}
