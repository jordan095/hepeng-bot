{
  "name": "hepeng-bot",
  "version": "1.0.0",
  "description": "WhatsApp Bot untuk tracking pengeluaran dan pemasukan pribadi",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch --ignore bot.log src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
